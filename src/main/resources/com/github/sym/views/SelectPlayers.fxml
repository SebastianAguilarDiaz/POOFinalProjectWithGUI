<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<!-- <?import javafx.scene.control.RadioButton?> -->

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Text?>

<VBox alignment="TOP_LEFT" spacing="15.0"  xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.github.sym.controllers.SelectPlayersController">

   <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>

   <children>

        <Text text = "Escoja los jugadores para la partida" style="-fx-font-size: 20 px; -fx-font-weight: bold;"/>
        <VBox alignment="TOP_LEFT" spacing="15.0" />
        <Button text="Empezar juego"            onAction="#startFunction"   prefWidth="200" style="-fx-font-size: 14px;"/>
        <Button text="Regresar" onAction="#returnFunction"/>
   </children>
   
</VBox>